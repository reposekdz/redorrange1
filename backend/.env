# ── Server
NODE_ENV=development
PORT=5000

# ── Database (PostgreSQL via Replit)
DATABASE_URL=postgresql://postgres:password@helium/heliumdb?sslmode=disable

# ── JWT
JWT_SECRET=your-super-secret-jwt-key-min-64-chars-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-min-64-chars-change-in-production
JWT_EXPIRES_IN=30d

# ── File Storage
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=http://localhost:5000/uploads
MAX_FILE_SIZE_MB=50

# ── Twilio (SMS/OTP) - Not configured for dev (OTP printed to console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── STRIPE (not configured for dev)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── PAYPAL (not configured for dev)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ── FLUTTERWAVE (not configured for dev)
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=

# ── Frontend URL (for payment redirects)
FRONTEND_URL=http://localhost:5000
REDIRECT_URL=http://localhost:5000/payment/callback

# ── Coins
COINS_PER_DOLLAR=200
PAYOUT_RATE_PER_100_COINS=0.50

# ── OTP
OTP_EXPIRY_MINUTES=10
QR_CODE_EXPIRY_MINUTES=5
