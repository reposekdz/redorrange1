# ── Server
NODE_ENV=development
PORT=5000

# ── Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=redorrange

# ── JWT
JWT_SECRET=your-super-secret-jwt-key-min-64-chars-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-min-64-chars-change-in-production
JWT_EXPIRES_IN=30d

# ── File Storage
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=http://localhost:3000/uploads
MAX_FILE_SIZE_MB=50

# ── Twilio (SMS/OTP)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── STRIPE
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# For testing: sk_test_... and pk_test_...

# ── PAYPAL
PAYPAL_CLIENT_ID=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYPAL_CLIENT_SECRET=EJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYPAL_MODE=sandbox
# Production: PAYPAL_MODE=live

# ── FLUTTERWAVE
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# Mobile money numbers supported: MTN Rwanda, Airtel Rwanda, M-Pesa Kenya, etc.

# ── Frontend URL (for payment redirects)
FRONTEND_URL=http://localhost:3000
REDIRECT_URL=https://redorrange.app/payment/callback

# ── Redis (optional)
REDIS_URL=redis://localhost:6379

# ── STRIPE (real keys from dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── PAYPAL (real keys from developer.paypal.com)
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=...

# ── FLUTTERWAVE (real keys from dashboard.flutterwave.com)
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-...
FLUTTERWAVE_SECRET_KEY=FLWSECK-...
FLUTTERWAVE_ENCRYPTION_KEY=...
FLUTTERWAVE_SECRET_HASH=...

# ── COIN RATE (1 USD = how many coins)
COINS_PER_DOLLAR=200
PAYOUT_RATE_PER_100_COINS=0.50

# ── Payment redirect (your domain)
REDIRECT_URL=https://redorrange.app/payment/callback
FRONTEND_URL=https://redorrange.app
